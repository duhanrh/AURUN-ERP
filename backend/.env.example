# ── AURUM ERP backend — variables de entorno (ejemplo) ──
# Copiar a .env y completar. NUNCA versionar el .env real (ver sección 10.10).

# Entorno: local | development | staging | production
AURUM_ENV=local

# API
AURUM_API_PREFIX=/api/v1
AURUM_DEBUG=true

# Base de datos PostgreSQL (driver async asyncpg)
AURUM_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aurum_dev

# Redis (cache / colas) — opcional en local
AURUM_REDIS_URL=redis://localhost:6379/0

# JWT (RS256). En local pueden ser claves de prueba; en prod, secret manager (sección 10.10).
AURUM_JWT_PRIVATE_KEY_PATH=
AURUM_JWT_PUBLIC_KEY_PATH=
AURUM_JWT_ACCESS_TTL_SECONDS=900
AURUM_JWT_REFRESH_TTL_SECONDS=1209600

# CORS (orígenes permitidos, separados por coma) — frontend Vite por defecto
AURUM_CORS_ORIGINS=http://localhost:5173
