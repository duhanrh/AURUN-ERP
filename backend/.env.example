# ── AURUM ERP backend — variables de entorno (ejemplo) ──
# Copiar a .env y completar. NUNCA versionar el .env real (ver sección 10.10).

# Entorno: local | development | staging | production
AURUM_ENV=local

# API
AURUM_API_PREFIX=/api/v1
AURUM_DEBUG=true

# Base de datos PostgreSQL — componentes independientes (la URL la arma config.py,
# aplicando URL-encoding a usuario/contraseña). La app conecta como el rol de
# aplicación aurum_app (NOBYPASSRLS), creado por scripts/db/setup_dev.sql.
AURUM_DB_HOST=localhost
AURUM_DB_PORT=5432
AURUM_DB_USER=aurum_app
AURUM_DB_PASSWORD=aurum_app
AURUM_DB_NAME=aurum_dev

# Bootstrap ÚNICO de la BD: superusuario de PostgreSQL (para crear rol+BD con psql).
# No se necesita en runtime. Acepta POSTGRES_SUPERUSER(_PASSWORD) o el prefijo AURUM_.
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=

# Redis (cache / colas) — opcional en local
AURUM_REDIS_URL=redis://localhost:6379/0

# JWT (RS256). En local pueden ser claves de prueba; en prod, secret manager (sección 10.10).
AURUM_JWT_PRIVATE_KEY_PATH=
AURUM_JWT_PUBLIC_KEY_PATH=
AURUM_JWT_ACCESS_TTL_SECONDS=900
AURUM_JWT_REFRESH_TTL_SECONDS=1209600

# CORS (orígenes permitidos, separados por coma) — frontend Vite por defecto
AURUM_CORS_ORIGINS=http://localhost:5173
